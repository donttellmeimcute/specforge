{
  "name": "specforge",
  "version": "0.1.0",
  "description": "Spec-Driven Development framework — structured workflow for AI-assisted development",
  "type": "module",
  "license": "MIT",
  "bin": {
    "specforge": "./bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "release": "changeset publish",
    "copy-assets": "node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@inquirer/prompts": "^7.10.1",
    "@octokit/rest": "^22.0.1",
    "asana": "^3.1.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.2",
    "inquirer": "^13.3.0",
    "omelette": "^0.4.17",
    "ora": "^8.1.0",
    "posthog-node": "^5.28.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.0.0",
    "@types/asana": "^0.18.17",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "spec-driven-development",
    "sdd",
    "specifications",
    "ai-assisted",
    "workflow",
    "cli"
  ]
}
